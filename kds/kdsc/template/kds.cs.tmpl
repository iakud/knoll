{{- else if eq .Type "sint32"}}
				sb.AppendLine(indent + "  " + v.ToString());
{{- else if eq .Type "uint32"}}
				sb.AppendLine(indent + "  " + v.ToString());
{{- else if eq .Type "int64"}}
				sb.AppendLine(indent + "  " + v.ToString());
{{- else if eq .Type "sint64"}}
				sb.AppendLine(indent + "  " + v.ToString());
{{- else if eq .Type "uint64"}}
				sb.AppendLine(indent + "  " + v.ToString());
{{- else if eq .Type "fixed32"}}
				sb.AppendLine(indent + "  " + v.ToString());
{{- else if eq .Type "sfixed32"}}
				sb.AppendLine(indent + "  " + v.ToString());
{{- else if eq .Type "fixed64"}}
				sb.AppendLine(indent + "  " + v.ToString());
{{- else if eq .Type "sfixed64"}}
				sb.AppendLine(indent + "  " + v.ToString());
{{- else if eq .Type "float"}}
				sb.AppendLine(indent + "  " + v.ToString(System.Globalization.CultureInfo.InvariantCulture));
{{- else if eq .Type "double"}}
				sb.AppendLine(indent + "  " + v.ToString(System.Globalization.CultureInfo.InvariantCulture));
{{- else if eq .Type "string"}}
				sb.AppendLine(indent + "  " + v);
{{- else if eq .Type "bytes"}}
				sb.AppendLine(indent + "  " + Convert.ToBase64String(v));
{{- else if eq .Type "timestamp"}}
				sb.AppendLine(indent + "  {Seconds: " + v.Seconds + ", Nanos: " + v.Nanos + "}");
{{- else if eq .Type "duration"}}
				sb.AppendLine(indent + "  {Seconds: " + v.Seconds + ", Nanos: " + v.Nanos + "}");
{{- else if eq .Type "empty"}}
				sb.AppendLine(indent + "  {}");
{{- end}}
			}
			sb.Append(indent + "]");
			return sb.ToString();
		}

		public void ApplySync(byte[] b)
		{
			Clear();
			var stream = new CodedInputStream(b);
			while (!stream.IsAtEnd)
			{
{{- if eq .TypeKind "component"}}
				var v = new {{.Type}}();
				v.ApplySync(stream.ReadBytes().ToByteArray());
				Add(v);
{{- else if eq .TypeKind "enum"}}
				Add(({{.Type}})stream.ReadEnum());
{{- else if eq .Type "bool"}}
				Add(stream.ReadBool());
{{- else if eq .Type "int32"}}
				Add(stream.ReadInt32());
{{- else if eq .Type "sint32"}}
				Add(stream.ReadSInt32());
{{- else if eq .Type "uint32"}}
				Add(stream.ReadUInt32());
{{- else if eq .Type "int64"}}
				Add(stream.ReadInt64());
{{- else if eq .Type "sint64"}}
				Add(stream.ReadSInt64());
{{- else if eq .Type "uint64"}}
				Add(stream.ReadUInt64());
{{- else if eq .Type "fixed32"}}
				Add(stream.ReadFixed32());
{{- else if eq .Type "sfixed32"}}
				Add(stream.ReadSFixed32());
{{- else if eq .Type "fixed64"}}
				Add(stream.ReadFixed64());
{{- else if eq .Type "sfixed64"}}
				Add(stream.ReadSFixed64());
{{- else if eq .Type "float"}}
				Add(stream.ReadFloat());
{{- else if eq .Type "double"}}
				Add(stream.ReadDouble());
{{- else if eq .Type "string"}}
				Add(stream.ReadString());
{{- else if eq .Type "bytes"}}
				Add(stream.ReadBytes());
{{- else if eq .Type "timestamp"}}
				Add(Timestamp.Parser.ParseFrom(stream.ReadBytes().ToByteArray()));
{{- else if eq .Type "duration"}}
				Add(Duration.Parser.ParseFrom(stream.ReadBytes().ToByteArray()));
{{- else if eq .Type "empty"}}
				Add(Empty.Parser.ParseFrom(stream.ReadBytes().ToByteArray()));
{{- end}}
			}
		}

		public void RaiseChanged()
