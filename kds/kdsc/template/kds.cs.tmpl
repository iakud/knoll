		public static void ApplySync(Dictionary<{{template "Type" .KeyType}}, {{template "MapValueType" .}}> data, byte[] b)
		{
			var stream = new CodedInputStream(b);
			var clear = false;
			byte[] deletes = [];
			var entries = new List<byte[]>();
			uint tag;
			while ((tag = stream.ReadTag()) != 0)
			{
				var num = WireFormat.GetTagFieldNumber(tag);
				switch (num)
				{
				case 1: // MapClearFieldNumber
					clear = stream.ReadBool();
					break;
				case 2: // MapDeleteFieldNumber
					deletes = stream.ReadBytes().ToByteArray();
					break;
				case 3: // MapEntryFieldNumber
					entries.Add(stream.ReadBytes().ToByteArray());
					break;
				default:
					stream.SkipLastField();
					break;
				}
			}
			if (clear)
			{
				data.Clear();
			}
			stream = new CodedInputStream(deletes);
			while (!stream.IsAtEnd)
			{
{{- if eq .KeyType "int32"}}
				data.Remove(stream.ReadInt32());
{{- else if eq .KeyType "int64"}}
				data.Remove(stream.ReadInt64());
{{- else if eq .KeyType "uint32"}}
				data.Remove(stream.ReadUInt32());
{{- else if eq .KeyType "uint64"}}
				data.Remove(stream.ReadUInt64());
{{- else if eq .KeyType "sint64"}}
				data.Remove(stream.ReadSInt32());
{{- else if eq .KeyType "sint64"}}
				data.Remove(stream.ReadSInt64());
{{- else if eq .KeyType "sfixed32"}}
				data.Remove(stream.ReadSFixed32());
{{- else if eq .KeyType "sfixed64"}}
				data.Remove(stream.ReadSFixed64());
{{- else if eq .KeyType "bool"}}
				data.Remove(stream.ReadBool());
{{- else if eq .KeyType "string"}}
				data.Remove(stream.ReadString());
{{- else}}
				stream.SkipLastField();
{{- end}}
			}
			foreach (var entry in entries)
			{
				stream = new CodedInputStream(entry);
{{- if eq .KeyType "string"}}
				string k = string.Empty;
{{- else}}
				{{template "Type" .KeyType}} k = default;
{{- end}}
{{- if eq .TypeKind "component"}}
				byte[] v = [];
{{- else if eq .TypeKind "enum"}}
				{{.Type}} v = default;
{{- else if eq .Type "string"}}
				string v = string.Empty;
{{- else if eq .Type "timestamp" "duration" "empty"}}
				{{template "MapValueType" .}} v = new {{template "MapValueType" .}}();
{{- else}}
				{{template "MapValueType" .}} v = default;
{{- end}}
				while ((tag = stream.ReadTag()) != 0)
				{
					var num = WireFormat.GetTagFieldNumber(tag);
					switch (num)
					{
					case 1: // MapEntryKeyFieldNumber
{{- if eq .KeyType "int32"}}
						k = stream.ReadInt32();
{{- else if eq .KeyType "int64"}}
						k = stream.ReadInt64();
{{- else if eq .KeyType "uint32"}}
						k = stream.ReadUInt32();
{{- else if eq .KeyType "uint64"}}
						k = stream.ReadUInt64();
{{- else if eq .KeyType "sint64"}}
						k = stream.ReadSInt32();
{{- else if eq .KeyType "sint64"}}
						k = stream.ReadSInt64();
{{- else if eq .KeyType "sfixed32"}}
						k = stream.ReadSFixed32();
{{- else if eq .KeyType "sfixed64"}}
						k = stream.ReadSFixed64();
{{- else if eq .KeyType "bool"}}
						k = stream.ReadBool();
{{- else if eq .KeyType "string"}}
						k = stream.ReadString();
{{- else}}
						stream.SkipLastField();
{{- end}}
						break;
					case 2: // MapEntryValueFieldNumber
{{- if eq .TypeKind "component"}}
						v = stream.ReadBytes().ToByteArray();
{{- else if eq .TypeKind "enum"}}
						v = ({{.Type}})stream.ReadEnum();
{{- else if eq .Type "bool"}}
						v = stream.ReadBool();
{{- else if eq .Type "int32"}}
						v = stream.ReadInt32();
{{- else if eq .Type "sint32"}}
						v = stream.ReadSInt32();
{{- else if eq .Type "uint32"}}
						v = stream.ReadUInt32();
{{- else if eq .Type "int64"}}
						v = stream.ReadInt64();
{{- else if eq .Type "sint64"}}
						v = stream.ReadSInt64();
{{- else if eq .Type "uint64"}}
						v = stream.ReadUInt64();
{{- else if eq .Type "fixed32"}}
						v = stream.ReadFixed32();
{{- else if eq .Type "sfixed32"}}
						v = stream.ReadSFixed32();
{{- else if eq .Type "fixed64"}}
						v = stream.ReadFixed64();
{{- else if eq .Type "sfixed64"}}
						v = stream.ReadSFixed64();
{{- else if eq .Type "float"}}
						v = stream.ReadFloat();
{{- else if eq .Type "double"}}
						v = stream.ReadDouble();
{{- else if eq .Type "string"}}
						v = stream.ReadString();
{{- else if eq .Type "bytes"}}
						v = stream.ReadBytes().ToByteArray();
{{- else if eq .Type "timestamp"}}
						v = Timestamp.Parser.ParseFrom(stream.ReadBytes().ToByteArray());
{{- else if eq .Type "duration"}}
						v = Duration.Parser.ParseFrom(stream.ReadBytes().ToByteArray());
{{- else if eq .Type "empty"}}
						v = Empty.Parser.ParseFrom(stream.ReadBytes().ToByteArray());
{{- else}}
						stream.SkipLastField();
{{- end}}
						break;
					default:
						stream.SkipLastField();
						break;
					}
				}
{{- if eq .TypeKind "component"}}
				if (data.TryGetValue(k, out var c))
				{
					c.ApplySync(v);	
				}
				else
				{
					c = new {{.Type}}();
					c.ApplySync(v);
					data[k] = c;
				}
{{- else}}
				data[k] = v;
{{- end}}
			}
		}

